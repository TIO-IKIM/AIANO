# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=aiano
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# CORS Configuration
# Use * for development, specify origins for production (comma-separated)
CORS_ORIGINS=*

# Allowed Hosts
# Use * for development, specify hosts for production (comma-separated)
ALLOWED_HOSTS=*

# JWT Secret (for production, use a secure random string)
JWT_SECRET=your-secret-key-change-in-production
